# ── Pinterest ─────────────────────────────────────────────────────────
# How to get a Pinterest access token:
#   1. Go to https://developers.pinterest.com/apps/
#   2. Create a new app (or open an existing one)
#   3. In your app settings, click "Generate access token"
#   4. Check these scopes:
#        boards:read   boards:write   pins:read   pins:write
#   5. Copy the generated token below
#
PINTEREST_ACCESS_TOKEN=your_access_token_here

# ── Etsy (optional — for new-listing auto-upload) ─────────────────────
# How to get Etsy credentials:
#   1. Go to https://www.etsy.com/developers/register
#   2. Create an app and copy your API key
#   3. Find your Shop ID at https://www.etsy.com/developers/your-apps
#      or via: GET https://openapi.etsy.com/v3/application/shops?shop_name=BrandonFranksPottery
#
ETSY_API_KEY=your_etsy_api_key_here
ETSY_SHOP_ID=your_shop_id_here
